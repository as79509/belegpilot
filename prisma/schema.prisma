generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum DocumentStatus {
  neu
  gelesen
  geprueft
  exportiert
}

model Client {
  id                      String     @id @default(cuid())
  name                    String
  shortName               String
  companyName             String?
  uid                     String?
  currency                String     @default("CHF")
  defaultCreditAccount    String
  defaultExpenseAccount   String
  externalReferencePrefix String
  bookingMethodNote       String?
  chartOfAccountsRawText  String?
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt
  accounts                Account[]
  documents               Document[]

  @@unique([shortName])
}

model Account {
  id        String   @id @default(cuid())
  clientId  String
  accountNo String
  name      String
  kind      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, accountNo])
  @@index([clientId, isActive])
}

model Document {
  id                        String         @id @default(cuid())
  clientId                  String
  originalFilename          String
  storedPath                String
  mimeType                  String
  status                    DocumentStatus @default(neu)
  supplierName              String?
  documentDate              DateTime?
  invoiceDate               DateTime?
  dueDate                   DateTime?
  invoiceNumber             String?
  currency                  String?
  grossAmount               Float?
  taxHint                   String?
  description               String?
  suggestedExpenseAccountNo String?
  confirmedExpenseAccountNo String?
  creditAccountNo           String?
  externalReference         String         @unique
  aiReasoningShort          String?
  aiConfidenceLabel         String?
  aiRawJson                 String?
  exportedAt                DateTime?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
  client                    Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, status])
  @@index([clientId, createdAt])
  @@index([clientId, documentDate])
}

model AppSetting {
  id                            String   @id @default("app")
  appName                       String   @default("BelegPilot Lite")
  defaultCurrency               String   @default("CHF")
  aiBaseUrl                     String?
  aiApiKey                      String?
  aiModel                       String?
  aiOcrModel                    String?
  aiTimeoutMs                   Int      @default(45000)
  exportDefaultCreditAccount    String?
  exportDefaultExpenseAccount   String?
  defaultDateBehavior           String   @default("document_first")
  globalExternalReferencePrefix String   @default("BPL")
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
}
