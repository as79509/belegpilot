generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ──

enum UserRole {
  admin
  reviewer
  accounting
  readonly
}

enum DocumentStatus {
  uploaded
  processing
  extracted
  validated
  needs_review
  ready
  exported
  export_failed
  rejected
  failed
  archived
}

enum DocumentType {
  invoice
  credit_note
  receipt
  reminder
  other
}

enum ProcessingDecision {
  auto_ready
  needs_review
  failed
}

enum ReviewStatus {
  pending
  approved
  rejected
}

enum ExportStatus {
  not_exported
  exporting
  exported
  export_failed
}

enum ProcessingStepStatus {
  started
  completed
  failed
}

enum IntegrationProviderType {
  ocr
  ai
  export
}

enum RuleType {
  supplier_default
  auto_approve
  category_mapping
  vat_logic
}

// ── Models ──

model Company {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  legalName String   @map("legal_name")
  vatNumber String?  @map("vat_number")
  address   Json?
  currency  String   @default("CHF") @db.VarChar(3)
  settings  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users        User[]
  documents    Document[]
  suppliers    Supplier[]
  auditLogs    AuditLog[]
  integrations Integration[]
  rules        Rule[]

  @@map("companies")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  companyId    String    @map("company_id") @db.Uuid
  email        String    @unique
  name         String
  passwordHash String    @map("password_hash")
  role         UserRole  @default(readonly)
  isActive     Boolean   @default(true) @map("is_active")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  company           Company    @relation(fields: [companyId], references: [id])
  reviewedDocuments  Document[] @relation("ReviewedBy")
  auditLogs         AuditLog[]

  @@map("users")
}

model Document {
  id                     String              @id @default(uuid()) @db.Uuid
  companyId              String              @map("company_id") @db.Uuid
  status                 DocumentStatus      @default(uploaded)
  documentType           DocumentType        @default(other) @map("document_type")

  // Extracted fields (canonical)
  supplierNameRaw        String?             @map("supplier_name_raw")
  supplierNameNormalized String?             @map("supplier_name_normalized")
  supplierId             String?             @map("supplier_id") @db.Uuid
  invoiceNumber          String?             @map("invoice_number")
  invoiceDate            DateTime?           @map("invoice_date")
  dueDate                DateTime?           @map("due_date")
  currency               String?             @db.VarChar(3)
  netAmount              Decimal?            @map("net_amount") @db.Decimal(12, 2)
  vatAmount              Decimal?            @map("vat_amount") @db.Decimal(12, 2)
  grossAmount            Decimal?            @map("gross_amount") @db.Decimal(12, 2)
  vatRatesDetected       Json?               @map("vat_rates_detected")
  iban                   String?
  paymentReference       String?             @map("payment_reference")

  // Categorization
  expenseCategory        String?             @map("expense_category")
  accountCode            String?             @map("account_code")
  costCenter             String?             @map("cost_center")

  // Processing metadata
  confidenceScore        Float?              @map("confidence_score")
  processingDecision     ProcessingDecision? @map("processing_decision")
  validationResults      Json?               @map("validation_results")

  // Review
  reviewStatus           ReviewStatus        @default(pending) @map("review_status")
  reviewNotes            String?             @map("review_notes")
  reviewedBy             String?             @map("reviewed_by") @db.Uuid
  reviewedAt             DateTime?           @map("reviewed_at")

  // Export
  exportStatus           ExportStatus        @default(not_exported) @map("export_status")

  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")

  company         Company          @relation(fields: [companyId], references: [id])
  supplier        Supplier?        @relation(fields: [supplierId], references: [id])
  reviewer        User?            @relation("ReviewedBy", fields: [reviewedBy], references: [id])
  file            DocumentFile?
  ocrResult       OcrResult?
  aiResults       AiResult[]
  processingSteps ProcessingStep[]
  exportRecords   ExportRecord[]

  @@index([companyId, status])
  @@index([companyId, supplierId])
  @@index([companyId, invoiceDate])
  @@index([companyId, exportStatus])
  @@map("documents")
}

model DocumentFile {
  id         String   @id @default(uuid()) @db.Uuid
  documentId String   @unique @map("document_id") @db.Uuid
  filePath   String   @map("file_path")
  fileName   String   @map("file_name")
  mimeType   String   @map("mime_type")
  fileSize   Int      @map("file_size")
  fileHash   String   @map("file_hash")
  createdAt  DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([fileHash])
  @@map("document_files")
}

model OcrResult {
  id               String   @id @default(uuid()) @db.Uuid
  documentId       String   @unique @map("document_id") @db.Uuid
  provider         String
  rawPayload       Json     @map("raw_payload")
  confidence       Float?
  pageCount        Int?     @map("page_count")
  processingTimeMs Int?     @map("processing_time_ms")
  createdAt        DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("ocr_results")
}

model AiResult {
  id               String   @id @default(uuid()) @db.Uuid
  documentId       String   @map("document_id") @db.Uuid
  version          Int      @default(1)
  provider         String
  promptVersion    String?  @map("prompt_version")
  rawPayload       Json     @map("raw_payload")
  normalizedData   Json     @map("normalized_data")
  confidence       Float?
  processingTimeMs Int?     @map("processing_time_ms")
  createdAt        DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("ai_results")
}

model Supplier {
  id                 String   @id @default(uuid()) @db.Uuid
  companyId          String   @map("company_id") @db.Uuid
  nameNormalized     String   @map("name_normalized")
  nameVariants       Json     @default("[]") @map("name_variants")
  vatNumber          String?  @map("vat_number")
  iban               String?
  address            Json?
  country            String?  @db.VarChar(2)
  defaultCategory    String?  @map("default_category")
  defaultAccountCode String?  @map("default_account_code")
  defaultCostCenter  String?  @map("default_cost_center")
  defaultVatCode     String?  @map("default_vat_code")
  documentCount      Int      @default(0) @map("document_count")
  isVerified         Boolean  @default(false) @map("is_verified")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  company   Company    @relation(fields: [companyId], references: [id])
  documents Document[]

  @@index([companyId, nameNormalized])
  @@index([companyId, vatNumber])
  @@index([companyId, iban])
  @@map("suppliers")
}

model ProcessingStep {
  id           String               @id @default(uuid()) @db.Uuid
  documentId   String               @map("document_id") @db.Uuid
  stepName     String               @map("step_name")
  status       ProcessingStepStatus
  startedAt    DateTime             @map("started_at")
  completedAt  DateTime?            @map("completed_at")
  durationMs   Int?                 @map("duration_ms")
  errorMessage String?              @map("error_message")
  errorDetails Json?                @map("error_details")
  metadata     Json?

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("processing_steps")
}

model ExportRecord {
  id               String   @id @default(uuid()) @db.Uuid
  documentId       String   @map("document_id") @db.Uuid
  exportTarget     String   @map("export_target")
  status           String
  externalId       String?  @map("external_id")
  errorMessage     String?  @map("error_message")
  payloadSent      Json?    @map("payload_sent")
  responseReceived Json?    @map("response_received")
  createdAt        DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("export_records")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  companyId  String   @map("company_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  changes    Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@index([companyId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model Integration {
  id             String                  @id @default(uuid()) @db.Uuid
  companyId      String                  @map("company_id") @db.Uuid
  providerType   IntegrationProviderType @map("provider_type")
  providerName   String                  @map("provider_name")
  credentials    Json?
  isEnabled      Boolean                 @default(false) @map("is_enabled")
  lastTestedAt   DateTime?               @map("last_tested_at")
  lastTestStatus String?                 @map("last_test_status")
  settings       Json?
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, providerType, providerName])
  @@map("integrations")
}

model Rule {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  name      String
  ruleType  RuleType @map("rule_type")
  conditions Json
  actions    Json
  priority   Int      @default(0)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, ruleType])
  @@map("rules")
}
