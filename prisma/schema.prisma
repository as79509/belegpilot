generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ──

enum UserRole {
  admin
  reviewer
  accounting
  readonly
  trustee
}

enum DocumentStatus {
  uploaded
  processing
  extracted
  validated
  needs_review
  ready
  exported
  export_failed
  rejected
  failed
  archived
}

enum DocumentType {
  invoice
  credit_note
  receipt
  reminder
  other
}

enum ProcessingDecision {
  auto_ready
  needs_review
  failed
}

enum ReviewStatus {
  pending
  approved
  rejected
}

enum ExportStatus {
  not_exported
  exporting
  exported
  export_failed
}

enum ProcessingStepStatus {
  started
  completed
  failed
}

enum IntegrationProviderType {
  ocr
  ai
  export
}

enum RuleType {
  supplier_default
  auto_approve
  category_mapping
  vat_logic
  escalation
}

// ── Models ──

model Company {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  legalName String   @map("legal_name")
  vatNumber String?  @map("vat_number")
  address   Json?
  currency  String   @default("CHF") @db.VarChar(3)
  settings  Json?

  // Erweiterte Mandanten-Daten
  legalForm          String?   @map("legal_form")
  uid                String?   @map("uid_number")
  industry           String?
  subIndustry        String?   @map("sub_industry")
  businessModel      String?   @map("business_model") @db.Text
  employeeCount      Int?      @map("employee_count")
  foundedAt          DateTime? @map("founded_at")
  fiscalYearStart    Int?      @map("fiscal_year_start")
  phone              String?
  email              String?
  website            String?
  timezone           String?   @default("Europe/Zurich")
  language           String?   @default("de") @db.VarChar(5)
  status             String?   @default("active")

  // MwSt
  vatLiable          Boolean   @default(true) @map("vat_liable")
  vatMethod          String?   @map("vat_method")
  vatInterval        String?   @map("vat_interval")
  vatFlatRate         Float?   @map("vat_flat_rate")

  // Buchhaltung
  chartOfAccounts    String?   @map("chart_of_accounts")
  costCentersEnabled Boolean   @default(false) @map("cost_centers_enabled")
  projectsEnabled    Boolean   @default(false) @map("projects_enabled")

  // KI
  aiContext              String?  @map("ai_context") @db.Text
  aiConfidenceThreshold  Float?   @map("ai_confidence_threshold")
  aiAutoApprove          Boolean  @default(false) @map("ai_auto_approve")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users        User[]
  documents    Document[]
  suppliers    Supplier[]
  auditLogs    AuditLog[]
  integrations Integration[]
  rules         Rule[]
  aiUsages        AiUsage[]
  userCompanies   UserCompany[]
  journalEntries   JournalEntry[]
  recurringEntries  RecurringEntry[]
  assets            Asset[]
  escalationRules   EscalationRule[]
  knowledgeItems    KnowledgeItem[]
  contracts          Contract[]
  expectedDocuments  ExpectedDocument[]
  monthlyPeriods     MonthlyPeriod[]
  tasks              Task[]
  bookingSuggestions BookingSuggestion[]
  correctionEvents   CorrectionEvent[]
  correctionPatterns CorrectionPattern[]
  autopilotConfig    AutopilotConfig?
  autopilotEvents    AutopilotEvent[]
  accounts           Account[]
  bankAccounts       BankAccount[]
  bankStatements     BankStatement[]
  bankTransactions   BankTransaction[]

  @@map("companies")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  companyId    String    @map("company_id") @db.Uuid
  email        String    @unique
  name         String
  passwordHash String    @map("password_hash")
  role         UserRole  @default(readonly)
  isActive     Boolean   @default(true) @map("is_active")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  company            Company        @relation(fields: [companyId], references: [id])
  reviewedDocuments  Document[]    @relation("ReviewedBy")
  auditLogs          AuditLog[]
  journalEntries     JournalEntry[] @relation("JournalEntryCreator")
  closedPeriods      MonthlyPeriod[] @relation("PeriodClosedBy")
  assignedTasks      Task[]         @relation("TaskAssignee")
  editedKnowledge    KnowledgeItem[] @relation("KnowledgeEditor")
  userCompanies              UserCompany[]
  bankTransactionMatches     BankTransaction[] @relation("BankTransactionMatcher")

  @@map("users")
}

model UserCompany {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  role      UserRole @default(readonly)
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
  @@map("user_companies")
}

model Document {
  id                     String              @id @default(uuid()) @db.Uuid
  companyId              String              @map("company_id") @db.Uuid
  documentNumber         String?             @unique @map("document_number")
  status                 DocumentStatus      @default(uploaded)
  documentType           DocumentType        @default(other) @map("document_type")

  // Extracted fields (canonical)
  supplierNameRaw        String?             @map("supplier_name_raw")
  supplierNameNormalized String?             @map("supplier_name_normalized")
  supplierId             String?             @map("supplier_id") @db.Uuid
  invoiceNumber          String?             @map("invoice_number")
  invoiceDate            DateTime?           @map("invoice_date")
  dueDate                DateTime?           @map("due_date")
  currency               String?             @db.VarChar(3)
  netAmount              Decimal?            @map("net_amount") @db.Decimal(12, 2)
  vatAmount              Decimal?            @map("vat_amount") @db.Decimal(12, 2)
  grossAmount            Decimal?            @map("gross_amount") @db.Decimal(12, 2)
  vatRatesDetected       Json?               @map("vat_rates_detected")
  iban                   String?
  paymentReference       String?             @map("payment_reference")

  // Categorization
  expenseCategory        String?             @map("expense_category")
  accountCode            String?             @map("account_code")
  costCenter             String?             @map("cost_center")

  // Processing metadata
  confidenceScore        Float?              @map("confidence_score")
  processingDecision     ProcessingDecision? @map("processing_decision")
  validationResults      Json?               @map("validation_results")

  // Decision Transparency
  decisionReasons        Json?               @map("decision_reasons")

  // Review
  reviewStatus           ReviewStatus        @default(pending) @map("review_status")
  reviewNotes            String?             @map("review_notes")
  reviewedBy             String?             @map("reviewed_by") @db.Uuid
  reviewedAt             DateTime?           @map("reviewed_at")

  // Export
  exportStatus           ExportStatus        @default(not_exported) @map("export_status")

  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")

  company         Company          @relation(fields: [companyId], references: [id])
  supplier        Supplier?        @relation(fields: [supplierId], references: [id])
  reviewer        User?            @relation("ReviewedBy", fields: [reviewedBy], references: [id])
  file            DocumentFile?
  ocrResult       OcrResult?
  aiResults       AiResult[]
  processingSteps ProcessingStep[]
  exportRecords   ExportRecord[]
  aiUsages        AiUsage[]
  journalEntries  JournalEntry[]
  relatedTasks    Task[]         @relation("TaskDocument")
  bookingSuggestions BookingSuggestion[]
  correctionEvents   CorrectionEvent[]
  autopilotEvents    AutopilotEvent[]
  bankTransactions   BankTransaction[]

  @@index([companyId, status])
  @@index([companyId, supplierId])
  @@index([companyId, invoiceDate])
  @@index([companyId, exportStatus])
  @@map("documents")
}

model DocumentFile {
  id         String   @id @default(uuid()) @db.Uuid
  documentId String   @unique @map("document_id") @db.Uuid
  filePath   String   @map("file_path")
  fileName   String   @map("file_name")
  mimeType   String   @map("mime_type")
  fileSize   Int      @map("file_size")
  fileHash   String   @map("file_hash")
  createdAt  DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([fileHash])
  @@map("document_files")
}

model OcrResult {
  id               String   @id @default(uuid()) @db.Uuid
  documentId       String   @unique @map("document_id") @db.Uuid
  provider         String
  rawPayload       Json     @map("raw_payload")
  confidence       Float?
  pageCount        Int?     @map("page_count")
  processingTimeMs Int?     @map("processing_time_ms")
  createdAt        DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("ocr_results")
}

model AiResult {
  id               String   @id @default(uuid()) @db.Uuid
  documentId       String   @map("document_id") @db.Uuid
  version          Int      @default(1)
  provider         String
  promptVersion    String?  @map("prompt_version")
  rawPayload       Json     @map("raw_payload")
  normalizedData   Json     @map("normalized_data")
  confidence       Float?
  processingTimeMs Int?     @map("processing_time_ms")
  createdAt        DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("ai_results")
}

model Supplier {
  id                 String   @id @default(uuid()) @db.Uuid
  companyId          String   @map("company_id") @db.Uuid
  nameNormalized     String   @map("name_normalized")
  nameVariants       Json     @default("[]") @map("name_variants")
  vatNumber          String?  @map("vat_number")
  iban               String?
  address            Json?
  country            String?  @db.VarChar(2)
  email              String?
  phone              String?
  website            String?
  contactPerson      String?  @map("contact_person")
  street             String?
  zip                String?
  city               String?
  notes              String?  @db.Text
  bankName           String?  @map("bank_name")
  bic                String?
  paymentTermDays    Int?     @map("payment_term_days")
  defaultCategory    String?  @map("default_category")
  defaultAccountCode String?  @map("default_account_code")
  defaultCostCenter  String?  @map("default_cost_center")
  defaultVatCode     String?  @map("default_vat_code")
  documentCount      Int      @default(0) @map("document_count")
  isVerified         Boolean  @default(false) @map("is_verified")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  company   Company    @relation(fields: [companyId], references: [id])
  documents Document[]
  contracts Contract[]

  @@index([companyId, nameNormalized])
  @@index([companyId, vatNumber])
  @@index([companyId, iban])
  @@map("suppliers")
}

model ProcessingStep {
  id           String               @id @default(uuid()) @db.Uuid
  documentId   String               @map("document_id") @db.Uuid
  stepName     String               @map("step_name")
  status       ProcessingStepStatus
  startedAt    DateTime             @map("started_at")
  completedAt  DateTime?            @map("completed_at")
  durationMs   Int?                 @map("duration_ms")
  errorMessage String?              @map("error_message")
  errorDetails Json?                @map("error_details")
  metadata     Json?

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("processing_steps")
}

model ExportRecord {
  id               String   @id @default(uuid()) @db.Uuid
  documentId       String   @map("document_id") @db.Uuid
  exportTarget     String   @map("export_target")
  status           String
  externalId       String?  @map("external_id")
  errorMessage     String?  @map("error_message")
  payloadSent      Json?    @map("payload_sent")
  responseReceived Json?    @map("response_received")
  createdAt        DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("export_records")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  companyId  String   @map("company_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  changes    Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@index([companyId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model Integration {
  id             String                  @id @default(uuid()) @db.Uuid
  companyId      String                  @map("company_id") @db.Uuid
  providerType   IntegrationProviderType @map("provider_type")
  providerName   String                  @map("provider_name")
  credentials    Json?
  isEnabled      Boolean                 @default(false) @map("is_enabled")
  lastTestedAt   DateTime?               @map("last_tested_at")
  lastTestStatus String?                 @map("last_test_status")
  settings       Json?
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, providerType, providerName])
  @@map("integrations")
}

model Rule {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  name      String
  ruleType  RuleType @map("rule_type")
  conditions Json
  actions    Json
  priority   Int      @default(0)
  isActive   Boolean  @default(true) @map("is_active")
  isGlobal   Boolean  @default(false) @map("is_global")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, ruleType])
  @@map("rules")
}

model AiUsage {
  id               String   @id @default(uuid()) @db.Uuid
  companyId        String   @map("company_id") @db.Uuid
  documentId       String   @map("document_id") @db.Uuid
  provider         String
  model            String
  inputTokens      Int      @map("input_tokens")
  outputTokens     Int      @map("output_tokens")
  estimatedCostUsd Decimal  @map("estimated_cost_usd") @db.Decimal(8, 4)
  createdAt        DateTime @default(now()) @map("created_at")

  company  Company  @relation(fields: [companyId], references: [id])
  document Document @relation(fields: [documentId], references: [id])

  @@index([companyId, createdAt])
  @@map("ai_usage")
}

model JournalEntry {
  id            String    @id @default(uuid()) @db.Uuid
  companyId     String    @map("company_id") @db.Uuid
  entryDate     DateTime  @map("entry_date")
  debitAccount  String    @map("debit_account")
  creditAccount String    @map("credit_account")
  amount        Decimal   @db.Decimal(12, 2)
  currency      String    @default("CHF") @db.VarChar(3)
  vatAmount     Decimal?  @map("vat_amount") @db.Decimal(12, 2)
  vatRate       Float?    @map("vat_rate")
  description   String
  reference     String?
  documentId    String?   @map("document_id") @db.Uuid
  entryType     String    @map("entry_type")
  isRecurring   Boolean   @default(false) @map("is_recurring")
  recurringId   String?   @map("recurring_id") @db.Uuid
  createdBy     String?   @map("created_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  company  Company   @relation(fields: [companyId], references: [id])
  document Document? @relation(fields: [documentId], references: [id])
  user     User?     @relation("JournalEntryCreator", fields: [createdBy], references: [id])

  @@index([companyId, entryDate])
  @@index([companyId, entryType])
  @@index([documentId])
  @@map("journal_entries")
}

model RecurringEntry {
  id              String    @id @default(uuid()) @db.Uuid
  companyId       String    @map("company_id") @db.Uuid
  name            String
  debitAccount    String    @map("debit_account")
  creditAccount   String    @map("credit_account")
  amount          Decimal   @db.Decimal(12, 2)
  currency        String    @default("CHF") @db.VarChar(3)
  vatAmount       Decimal?  @map("vat_amount") @db.Decimal(12, 2)
  description     String
  frequency       String
  dayOfMonth      Int       @default(1) @map("day_of_month")
  startDate       DateTime  @map("start_date")
  endDate         DateTime? @map("end_date")
  isActive        Boolean   @default(true) @map("is_active")
  lastGeneratedAt DateTime? @map("last_generated_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, isActive])
  @@map("recurring_entries")
}

model Asset {
  id                  String    @id @default(uuid()) @db.Uuid
  companyId           String    @map("company_id") @db.Uuid
  name                String
  category            String
  acquisitionDate     DateTime  @map("acquisition_date")
  acquisitionCost     Decimal   @map("acquisition_cost") @db.Decimal(12, 2)
  residualValue       Decimal   @default(0) @map("residual_value") @db.Decimal(12, 2)
  usefulLifeMonths    Int       @map("useful_life_months")
  depreciationMethod  String    @default("linear") @map("depreciation_method")
  degressiveRate      Float?    @map("degressive_rate")
  assetAccount        String    @map("asset_account")
  depreciationAccount String    @map("depreciation_account")
  location            String?
  costCenter          String?   @map("cost_center")
  assignedTo          String?   @map("assigned_to")
  description         String?   @db.Text
  serialNumber        String?   @map("serial_number")
  supplier            String?
  licensePlate        String?   @map("license_plate")
  privateUsePercent   Float?    @map("private_use_percent")
  status              String    @default("active")
  disposalDate        DateTime? @map("disposal_date")
  disposalAmount      Decimal?  @map("disposal_amount") @db.Decimal(12, 2)
  totalDepreciated    Decimal   @default(0) @map("total_depreciated") @db.Decimal(12, 2)
  bookValue           Decimal   @default(0) @map("book_value") @db.Decimal(12, 2)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  company   Company    @relation(fields: [companyId], references: [id])
  contracts    Contract[]
  relatedTasks Task[] @relation("TaskAsset")

  @@index([companyId, status])
  @@index([companyId, category])
  @@map("assets")
}

model EscalationRule {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  name      String
  condition String
  threshold Float?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, isActive])
  @@map("escalation_rules")
}

model KnowledgeItem {
  id              String   @id @default(uuid()) @db.Uuid
  companyId       String   @map("company_id") @db.Uuid
  category        String
  title           String
  content         String   @db.Text
  relatedSupplier String?  @map("related_supplier")
  relatedAccount  String?  @map("related_account")
  priority        Int      @default(0)
  isActive        Boolean  @default(true) @map("is_active")
  usableByAi      Boolean  @default(true) @map("usable_by_ai")
  validFrom       DateTime?  @map("valid_from")
  validUntil      DateTime?  @map("valid_until")
  documentType    String?    @map("document_type")
  isGlobal        Boolean    @default(false) @map("is_global")
  version         Int        @default(1)
  lastEditedBy    String?    @map("last_edited_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])
  editor  User?   @relation("KnowledgeEditor", fields: [lastEditedBy], references: [id])

  @@index([companyId, category])
  @@map("knowledge_items")
}

model Contract {
  id               String    @id @default(uuid()) @db.Uuid
  companyId        String    @map("company_id") @db.Uuid
  name             String
  contractType     String    @map("contract_type")
  counterparty     String
  startDate        DateTime  @map("start_date")
  endDate          DateTime? @map("end_date")
  noticePeriod     String?   @map("notice_period")
  autoRenew        Boolean   @default(false) @map("auto_renew")
  monthlyAmount    Decimal   @map("monthly_amount") @db.Decimal(12, 2)
  currency         String    @default("CHF") @db.VarChar(3)
  frequency        String
  debitAccount     String?   @map("debit_account")
  vatRate          Float?    @map("vat_rate")
  linkedSupplierId String?   @map("linked_supplier_id") @db.Uuid
  linkedAssetId    String?   @map("linked_asset_id") @db.Uuid
  depositAmount    Decimal?  @map("deposit_amount") @db.Decimal(12, 2)
  notes            String?   @db.Text
  status           String    @default("active")
  reminderDays     Int       @default(30) @map("reminder_days")
  lastInvoiceDate  DateTime? @map("last_invoice_date")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  company  Company   @relation(fields: [companyId], references: [id])
  supplier     Supplier? @relation(fields: [linkedSupplierId], references: [id])
  asset        Asset?    @relation(fields: [linkedAssetId], references: [id])
  relatedTasks      Task[]              @relation("TaskContract")
  expectedDocuments ExpectedDocument[]

  @@index([companyId, status])
  @@index([companyId, contractType])
  @@map("contracts")
}

model ExpectedDocument {
  id               String    @id @default(uuid()) @db.Uuid
  companyId        String    @map("company_id") @db.Uuid
  name             String
  counterparty     String
  frequency        String
  expectedAmount   Decimal?  @map("expected_amount") @db.Decimal(12, 2)
  tolerancePercent Float?    @default(20) @map("tolerance_percent")
  debitAccount     String?   @map("debit_account")
  linkedContractId String?   @map("linked_contract_id") @db.Uuid
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  company  Company   @relation(fields: [companyId], references: [id])
  contract Contract? @relation(fields: [linkedContractId], references: [id])

  @@index([companyId, isActive])
  @@map("expected_documents")
}

model MonthlyPeriod {
  id                    String    @id @default(uuid()) @db.Uuid
  companyId             String    @map("company_id") @db.Uuid
  year                  Int
  month                 Int
  status                String    @default("open")
  documentsExpected     Int       @default(0) @map("documents_expected")
  documentsReceived     Int       @default(0) @map("documents_received")
  recurringGenerated    Boolean   @default(false) @map("recurring_generated")
  depreciationGenerated Boolean   @default(false) @map("depreciation_generated")
  vatChecked            Boolean   @default(false) @map("vat_checked")
  exportCompleted       Boolean   @default(false) @map("export_completed")
  closedAt              DateTime? @map("closed_at")
  closedBy              String?   @map("closed_by") @db.Uuid
  notes                 String?   @db.Text
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  company      Company @relation(fields: [companyId], references: [id])
  closedByUser User?   @relation("PeriodClosedBy", fields: [closedBy], references: [id])

  @@unique([companyId, year, month])
  @@index([companyId, status])
  @@map("monthly_periods")
}

model Task {
  id                 String    @id @default(uuid()) @db.Uuid
  companyId          String    @map("company_id") @db.Uuid
  title              String
  description        String?   @db.Text
  taskType           String    @map("task_type")
  priority           String    @default("medium")
  status             String    @default("open")
  relatedDocumentId  String?   @map("related_document_id") @db.Uuid
  relatedAssetId     String?   @map("related_asset_id") @db.Uuid
  relatedContractId  String?   @map("related_contract_id") @db.Uuid
  assignedTo         String?   @map("assigned_to") @db.Uuid
  dueDate            DateTime? @map("due_date")
  source             String    @default("manual")
  messageBody        String?   @map("message_body") @db.Text
  messageSentAt      DateTime? @map("message_sent_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  company  Company   @relation(fields: [companyId], references: [id])
  document Document? @relation("TaskDocument", fields: [relatedDocumentId], references: [id])
  asset    Asset?    @relation("TaskAsset", fields: [relatedAssetId], references: [id])
  contract Contract? @relation("TaskContract", fields: [relatedContractId], references: [id])
  assignee User?     @relation("TaskAssignee", fields: [assignedTo], references: [id])

  @@index([companyId, status])
  @@index([companyId, priority])
  @@map("tasks")
}

model BookingSuggestion {
  id                String    @id @default(uuid()) @db.Uuid
  companyId         String    @map("company_id") @db.Uuid
  documentId        String    @map("document_id") @db.Uuid

  // Vorschlag
  suggestedAccount  String?   @map("suggested_account")
  suggestedCategory String?   @map("suggested_category")
  suggestedVatCode  String?   @map("suggested_vat_code")
  suggestedCostCenter String? @map("suggested_cost_center")

  // Bewertung
  confidenceLevel   String    @map("confidence_level")
  confidenceScore   Float     @map("confidence_score")

  // Begründung (strukturiert)
  reasoning         Json

  // Historische Basis
  matchedDocCount   Int       @map("matched_doc_count")
  consistencyRate   Float     @map("consistency_rate")

  // Status
  status            String    @default("pending")
  acceptedAt        DateTime? @map("accepted_at")
  rejectedAt        DateTime? @map("rejected_at")
  userModifiedTo    Json?     @map("user_modified_to")

  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  company   Company  @relation(fields: [companyId], references: [id])
  document  Document @relation(fields: [documentId], references: [id])

  @@index([companyId, documentId])
  @@index([companyId, status])
  @@map("booking_suggestions")
}

model CorrectionEvent {
  id              String   @id @default(uuid()) @db.Uuid
  companyId       String   @map("company_id") @db.Uuid
  documentId      String   @map("document_id") @db.Uuid
  supplierId      String?  @map("supplier_id") @db.Uuid

  // Was wurde korrigiert?
  field           String   // "accountCode", "expenseCategory", "vatRate", "costCenter"
  originalValue   String?  @map("original_value")   // AI/Suggestion Wert
  correctedValue  String   @map("corrected_value")  // Was der User gesetzt hat

  // Kontext
  correctedBy     String   @map("corrected_by") @db.Uuid
  source          String   @default("manual")  // "manual", "suggestion_modified", "review"

  createdAt       DateTime @default(now()) @map("created_at")

  company  Company  @relation(fields: [companyId], references: [id])
  document Document @relation(fields: [documentId], references: [id])

  @@index([companyId, supplierId, field])
  @@index([companyId, createdAt])
  @@map("correction_events")
}

model CorrectionPattern {
  id              String   @id @default(uuid()) @db.Uuid
  companyId       String   @map("company_id") @db.Uuid
  // supplierId stored as plain string (empty "" = no supplier) so that
  // the composite unique constraint works (Postgres treats null as distinct).
  supplierId      String   @default("") @map("supplier_id")
  supplierName    String?  @map("supplier_name")

  // Das Muster
  field           String   // "accountCode", "expenseCategory", "vatRate"
  fromValue       String   @map("from_value")   // AI sagt immer X
  toValue         String   @map("to_value")     // User ändert immer auf Y

  // Stärke
  occurrences     Int      @default(1)           // Wie oft dieses Muster
  firstSeenAt     DateTime @map("first_seen_at")
  lastSeenAt      DateTime @map("last_seen_at")

  // Status
  status           String    @default("open")  // "open", "promoted", "dismissed"
  promotedTo       String?   @map("promoted_to")  // "rule" | "knowledge" | "supplier_default"
  promotedEntityId String?   @map("promoted_entity_id") @db.Uuid
  promotedAt       DateTime? @map("promoted_at")
  dismissedAt      DateTime? @map("dismissed_at")
  dismissedReason  String?   @map("dismissed_reason")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, supplierId, field, fromValue, toValue])
  @@index([companyId, status])
  @@map("correction_patterns")
}

model AutopilotConfig {
  id                  String   @id @default(uuid()) @db.Uuid
  companyId           String   @unique @map("company_id") @db.Uuid

  // Steuerung
  enabled             Boolean  @default(false)
  mode                String   @default("shadow")  // "shadow", "prefill", "auto_ready"

  // Safety Gates
  minHistoryMatches   Int      @default(5)  @map("min_history_matches")
  minStabilityScore   Float    @default(0.8) @map("min_stability_score")
  maxAmount           Float?   @map("max_amount")
  minConfidence       Float    @default(0.85) @map("min_confidence")

  // Einschränkungen
  allowedDocTypes     Json?    @map("allowed_doc_types")
  allowedCurrencies   Json?    @map("allowed_currencies")
  supplierAllowlist   Json?    @map("supplier_allowlist")

  // Kill Switch
  killSwitchActive    Boolean   @default(false) @map("kill_switch_active")
  killSwitchBy        String?   @map("kill_switch_by") @db.Uuid
  killSwitchAt        DateTime? @map("kill_switch_at")
  killSwitchReason    String?   @map("kill_switch_reason")

  // Meta
  updatedBy           String?  @map("updated_by") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@map("autopilot_configs")
}

model AutopilotEvent {
  id                String   @id @default(uuid()) @db.Uuid
  companyId         String   @map("company_id") @db.Uuid
  documentId        String   @map("document_id") @db.Uuid

  // Entscheidung
  mode              String   // "shadow", "prefill", "auto_ready"
  decision          String   // "eligible", "blocked"

  // Safety Check Ergebnis
  safetyChecks      Json     @map("safety_checks")
  blockedBy         String?  @map("blocked_by")

  // Kontext
  confidenceScore   Float    @map("confidence_score")
  suggestedAccount  String?  @map("suggested_account")
  supplierName      String?  @map("supplier_name")

  createdAt         DateTime @default(now()) @map("created_at")

  company  Company  @relation(fields: [companyId], references: [id])
  document Document @relation(fields: [documentId], references: [id])

  @@index([companyId, decision])
  @@index([companyId, createdAt])
  @@map("autopilot_events")
}

model Account {
  id              String   @id @default(uuid()) @db.Uuid
  companyId       String   @map("company_id") @db.Uuid
  accountNumber   String   @map("account_number")      // z.B. "6200"
  name            String                                 // z.B. "Telekommunikation"
  accountType     String   @map("account_type")          // "asset" | "liability" | "equity" | "revenue" | "expense"
  category        String?                                // Unterkategorie z.B. "Betriebsaufwand"
  parentNumber    String?  @map("parent_number")         // z.B. "6000" für Hierarchie
  bclass          Int?                                    // Banana BClass (1=Aktiv, 2=Passiv, 3=Aufwand, 4=Ertrag)
  groupCode       String?  @map("group_code")            // Banana Gr
  currency        String?  @db.VarChar(3)
  isActive        Boolean  @default(true) @map("is_active")
  sortOrder       Int      @default(0) @map("sort_order")

  // AI Governance (4 Stufen)
  aiGovernance    String   @default("ai_suggest") @map("ai_governance")
  // "ai_suggest" = AI darf vorschlagen
  // "ai_autopilot" = AI darf Autopilot verwenden
  // "manual_only" = Nur manuelle Buchung
  // "locked" = Gesperrt (kein Zugriff)

  // Optionale Einschränkungen
  allowedDocTypes Json?    @map("allowed_doc_types")     // z.B. ["invoice", "credit_note"]
  allowedVatCodes Json?    @map("allowed_vat_codes")     // z.B. ["V81", "V00"]
  notes           String?  @db.Text

  // Banana Export Mapping
  bananaAccountNumber String? @map("banana_account_number")  // Falls abweichend
  bananaDescription   String? @map("banana_description")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company         Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, accountNumber])
  @@index([companyId, accountType])
  @@index([companyId, isActive])
  @@map("accounts")
}

model BankAccount {
  id            String   @id @default(uuid()) @db.Uuid
  companyId     String   @map("company_id") @db.Uuid
  name          String                           // z.B. "UBS Geschäftskonto"
  iban          String                           // CH93 0076 2011 6238 5295 7
  bic           String?
  bankName      String?  @map("bank_name")
  currency      String   @default("CHF") @db.VarChar(3)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  company       Company       @relation(fields: [companyId], references: [id])
  statements    BankStatement[]
  transactions  BankTransaction[]

  @@unique([companyId, iban])
  @@map("bank_accounts")
}

model BankStatement {
  id              String   @id @default(uuid()) @db.Uuid
  companyId       String   @map("company_id") @db.Uuid
  bankAccountId   String   @map("bank_account_id") @db.Uuid
  statementId     String?  @map("statement_id")      // camt.053 Identification
  sequenceNumber  String?  @map("sequence_number")
  fromDate        DateTime @map("from_date")
  toDate          DateTime @map("to_date")
  openingBalance  Decimal  @map("opening_balance") @db.Decimal(12, 2)
  closingBalance  Decimal  @map("closing_balance") @db.Decimal(12, 2)
  transactionCount Int     @map("transaction_count")
  fileName        String?  @map("file_name")
  importedAt      DateTime @default(now()) @map("imported_at")

  company       Company          @relation(fields: [companyId], references: [id])
  bankAccount   BankAccount      @relation(fields: [bankAccountId], references: [id])
  transactions  BankTransaction[]

  @@index([companyId, bankAccountId])
  @@map("bank_statements")
}

model BankTransaction {
  id                String   @id @default(uuid()) @db.Uuid
  companyId         String   @map("company_id") @db.Uuid
  bankAccountId     String   @map("bank_account_id") @db.Uuid
  statementId       String?  @map("statement_id") @db.Uuid

  // Transaktionsdaten
  bookingDate       DateTime @map("booking_date")
  valueDate         DateTime? @map("value_date")
  amount            Decimal  @db.Decimal(12, 2)
  currency          String   @default("CHF") @db.VarChar(3)
  isCredit          Boolean  @map("is_credit")           // true=Gutschrift, false=Belastung
  description       String?
  counterpartyName  String?  @map("counterparty_name")
  counterpartyIban  String?  @map("counterparty_iban")

  // Referenzen (aus camt.053)
  endToEndId        String?  @map("end_to_end_id")
  paymentReference  String?  @map("payment_reference")   // QR-Referenz, ESR, etc.
  remittanceInfo    String?  @map("remittance_info")
  bankReference     String?  @map("bank_reference")

  // Matching
  matchStatus       String   @default("unmatched") @map("match_status")
  // "unmatched" | "auto_matched" | "manual_matched" | "no_match"
  matchedDocumentId String?  @map("matched_document_id") @db.Uuid
  matchConfidence   Float?   @map("match_confidence")
  matchMethod       String?  @map("match_method")
  // "qr_reference" | "amount_date_iban" | "manual" | null
  matchedAt         DateTime? @map("matched_at")
  matchedBy         String?  @map("matched_by") @db.Uuid

  createdAt         DateTime @default(now()) @map("created_at")

  company       Company        @relation(fields: [companyId], references: [id])
  bankAccount   BankAccount    @relation(fields: [bankAccountId], references: [id])
  statement     BankStatement? @relation(fields: [statementId], references: [id])
  matchedDoc    Document?      @relation(fields: [matchedDocumentId], references: [id])
  matcher       User?          @relation("BankTransactionMatcher", fields: [matchedBy], references: [id])

  @@index([companyId, matchStatus])
  @@index([companyId, bookingDate])
  @@index([companyId, paymentReference])
  @@index([matchedDocumentId])
  @@map("bank_transactions")
}
